{
  "1": {"class_type": "CheckpointLoaderSimple",
        "inputs": {"ckpt_name": "v1-5-pruned-emaonly.safetensors"}},
  "2": {"class_type": "CLIPTextEncode",
        "inputs": {"clip": ["1", 1], "text": "a photo of a red sports car on a coastal road, golden hour"}},
  "3": {"class_type": "CLIPTextEncode",
        "inputs": {"clip": ["1", 1], "text": "blurry, low quality"}},
  "4": {"class_type": "EmptyLatentImage",
        "inputs": {"width": 512, "height": 512, "batch_size": 1}},

  "10": {"class_type": "AL_InjectionMatrix",
         "inputs": {"model": ["1", 0], "t_bins": 16, "preset": "flat", "value": 1.0}},
  "11": {"class_type": "AL_InjectionMatrixEdit",
         "inputs": {"matrix": ["10", 0], "model": ["1", 0], "layers": "out.0-3",
                    "t_start": 0.0, "t_end": 0.3, "op": "set", "value": 0.0}},
  "12": {"class_type": "AL_InjectionMatrixEdit",
         "inputs": {"matrix": ["11", 0], "model": ["1", 0], "layers": "mid",
                    "t_start": 0.3, "t_end": 0.7, "op": "mul", "value": 1.5}},
  "13": {"class_type": "AL_InjectionMatrixEdit",
         "inputs": {"matrix": ["12", 0], "model": ["1", 0], "layers": "in.*",
                    "t_start": 0.7, "t_end": 1.0, "op": "set", "value": 0.5}},
  "14": {"class_type": "AL_InjectionMatrixPreview",
         "inputs": {"matrix": ["13", 0], "colormap": "viridis", "annotate": true}},
  "15": {"class_type": "PreviewImage", "inputs": {"images": ["14", 0]}},

  "20": {"class_type": "AL_ApplyInjectionMatrix",
         "inputs": {"model": ["1", 0], "matrix": ["13", 0], "target": "attn2_out",
                    "apply_to": "cond", "cond_index": 0}},
  "21": {"class_type": "KSampler",
         "inputs": {"model": ["20", 0], "seed": 42, "steps": 20, "cfg": 7.0,
                    "sampler_name": "euler", "scheduler": "normal",
                    "positive": ["2", 0], "negative": ["3", 0],
                    "latent_image": ["4", 0], "denoise": 1.0}},
  "22": {"class_type": "VAEDecode", "inputs": {"samples": ["21", 0], "vae": ["1", 2]}},
  "23": {"class_type": "SaveImage",
         "inputs": {"images": ["22", 0], "filename_prefix": "AL_matrix"}}
}
